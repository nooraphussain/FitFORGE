<%- include('partials/user/header') %>

<section id="cart" class="bg-light py-5">
    <div class="container">
      <h1 class="section-title text-center mt-4" data-aos="fade-up">Your Cart</h1>
      
      <!-- Cart Items List -->
      <div class="row justify-content-center">
        <div class="col-md-8">
          <div class="cart-item-list">
            <!-- Cart Item 1 -->
            <div class="cart-item d-flex justify-content-between align-items-center py-4 border-bottom">
              <div class="cart-item-details d-flex">
                <div class="cart-item-image">
                  <img src="images/banner-image-1.jpg" alt="product" class="img-fluid" width="80">
                </div>
                <div class="cart-item-info ms-3">
                  <h5 class="item-title">Soft Leather Jacket</h5>
                  <p class="item-description">Crafted from the finest leather for maximum comfort and style.</p>
                </div>
              </div>
              <div class="cart-item-price">
                <span class="item-price">$99.99</span>
              </div>
              <div class="cart-item-quantity">
                <input type="number" value="1" min="1" class="quantity-input" />
              </div>
              <div class="cart-item-remove">
                <button class="btn btn-link text-danger">Remove</button>
              </div>
            </div>
  
            <!-- Cart Item 2 -->
            <div class="cart-item d-flex justify-content-between align-items-center py-4 border-bottom">
              <div class="cart-item-details d-flex">
                <div class="cart-item-image">
                  <img src="images/banner-image-2.jpg" alt="product" class="img-fluid" width="80">
                </div>
                <div class="cart-item-info ms-3">
                  <h5 class="item-title">Out Crop Sweater</h5>
                  <p class="item-description">A cozy sweater perfect for layering in the cooler months.</p>
                </div>
              </div>
              <div class="cart-item-price">
                <span class="item-price">$49.99</span>
              </div>
              <div class="cart-item-quantity">
                <input type="number" value="1" min="1" class="quantity-input" />
              </div>
              <div class="cart-item-remove">
                <button class="btn btn-link text-danger">Remove</button>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Cart Summary -->
      <div class="row justify-content-center mt-4">
        <div class="col-md-4">
          <div class="cart-summary">
            <div class="summary-item d-flex justify-content-between py-2">
              <span class="summary-label">Subtotal:</span>
              <span class="summary-value">$149.98</span>
            </div>
            <div class="summary-item d-flex justify-content-between py-2">
              <span class="summary-label">Tax (5%):</span>
              <span class="summary-value">$7.50</span>
            </div>
            <div class="summary-item d-flex justify-content-between py-2">
              <span class="summary-label">Total:</span>
              <span class="summary-value">$157.48</span>
            </div>
            <button class="btn btn-primary w-100 mt-3">Proceed to Checkout</button>
          </div>
        </div>
      </div>
    </div>
  </section>
  
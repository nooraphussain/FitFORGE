<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">

	<!-- Boxicons -->

	<link href='https://unpkg.com/boxicons@2.0.9/css/boxicons.min.css' rel='stylesheet'>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
	<!-- My CSS -->

    <link rel="stylesheet" href="/css/admin.css">    
	<title>AdminHub</title>
</head>
<body>


	<!-- SIDEBAR -->
	<section id="sidebar">
		<a href="/admin" class="brand">
            <i class='bx bxs-smile'></i>
            <span class="text">AdminHub</span>
        </a>
        
        <ul class="side-menu top">
            <li class="active">
                <a href="/admin">
                    <i class='bx bxs-dashboard'></i>
                    <span class="text">Dashboard</span>
                </a>
            </li>
			<li>
				<a href="/admin/products">
					<i class='bx bxs-shopping-bag-alt' ></i>
					<span class="text">Products</span>
				</a>
			</li>
			<li>
				<a href="/admin/orders">
					<i class='bx bxs-doughnut-chart' ></i>
					<span class="text">Orders</span>
				</a>
			</li>
			<li>
				<a href="/admin/category">
					<i class='bx bxs-category' ></i>
					<span class="text">Categories</span>
				</a>
			</li>
			<li>
				<a href="/admin/customers">
					<i class='bx bxs-group' ></i>
					<span class="text">Customers</span>
				</a>
			</li>
            <li>
				<a href="#">
					<i class='bx bxs-message-dots' ></i>
					<span class="text">Message</span>
				</a>
			</li>
		</ul>
		<ul class="side-menu">
            <li>
                <a href="#">
                    <i class='bx bxs-cog'></i>
                    <span class="text">Settings</span>
                </a>
            </li>
            <li>
                <a href="/admin/logout" class="logout">  <!-- Change href -->
                    <i class='bx bxs-log-out-circle'></i>
                    <span class="text">Logout</span>
                </a>
            </li>
        </ul>
        
	</section>
	<!-- SIDEBAR -->



	<!-- CONTENT -->
	<section id="content">
		<!-- NAVBAR -->
		<nav>
			<i class='bx bx-menu' ></i>
			<a href="#" class="nav-link">Categories</a>
			<form action="#">
				<div class="form-input">
					<input type="search" placeholder="Search...">
					<button type="submit" class="search-btn"><i class='bx bx-search' ></i></button>
				</div>
			</form>
			<input type="checkbox" id="switch-mode" hidden>
			<label for="switch-mode" class="switch-mode"></label>
			<a href="#" class="notification">
				<i class='bx bxs-bell' ></i>
				<span class="num">8</span>
			</a>
			<a href="#" class="profile">
				<img src="/images/admin.jpeg">
			</a>
		</nav>
		<!-- NAVBAR -->

		<!-- MAIN -->
		<main>
            <div class="head-title">
                <div class="left">
                    <h1>Customers</h1>
                    <ul class="breadcrumb">
                        <li><a href="/admin">Dashboard</a></li>
                        <li><i class='bx bx-chevron-right'></i></li>
                        <li><a class="active" href="/admin/customers">Customers</a></li>
                    </ul>
                </div>
                <div class="right flex items-center gap-4 w-full">
                    <!-- <a href="#" class="btn-download flex items-center gap-2 bg-blue-600 text-white px-4 py-2 rounded-lg shadow-md hover:bg-blue-700 transition-all duration-300">
                        <i class='bx bxs-cloud-download'></i>
                        <span class="text font-medium">Download PDF</span>
                    </a> -->
                    
                    <button class="filter-btn flex">
                        <i class="bx bx-search text-lg"></i>
                        <span class="text font-medium">Filter</span>
                    </button>
                    
                </div>
                
                <div class="table-data">
                    <div class="order">
                        <table>
                            <thead>
                                <tr>
                                    <th>Customer Name</th>
                                    <th>Email</th>
                                    <th>Phone</th>
                                    <th>Action</th>
                                    <th>Options</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% for(let i = 0; i < customers.length; i++) { %>
                                    <tr>
                                        <td><%= customers[i].name %></td>
                                        <td><%= customers[i].email %></td>
                                        <td><%= customers[i].phoneNumber %></td>
                                        <td>
                                            <% if (customers[i].isBlocked === true) { %>
                                                <a href="/admin/unblockCustomer?id=<%= customers[i]._id %>" class="custom-btn custom-btn-success">Unblock</a>
                                            <% } else { %>
                                                <a href="/admin/blockCustomer?id=<%= customers[i]._id %>" class="custom-btn custom-btn-danger">Block</a>
                                            <% } %>
                                        </td>
                                        <td>                                        
                                            <div class="dropdown">
                                                <button class="dots-btn">
                                                    <i class="bx bx-dots-horizontal-rounded"></i>
                                                </button>
                                                <div class="dropdown-menu">
                                                    <a href="#" class="dropdown-item">Show</a>
                                                    <a href="/admin/editCustomer?id=<%= customers[i]._id %>" class="dropdown-item">Edit</a>
                                                    <a href="/admin/deleteCustomer?id=<%= customers[i]._id %>" class="dropdown-item">Delete</a>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>                        
                        </table>

                    </div>
                </div>
            </div>   
        </main>
		<!-- MAIN -->
	</section>
	<!-- CONTENT -->
	

	<script src="/js/admin.js"></script>
</body>
</html>